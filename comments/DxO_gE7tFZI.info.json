imit": 0, "webpage_url": "https://www.youtube.com/watch?v=DxO_gE7tFZI", "categories": ["Entertainment"], "tags": ["ねぶたの家", "ワ・ラッセ", "ねぶたミュージアム", "青森 観光"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 2, "chapters": [{"start_time": 0.0, "title": "先頭", "end_time": 31.0}, {"start_time": 31.0, "title": "ねぶたの家ワ・ラッセ", "end_time": 56.0}, {"start_time": 56.0, "title": "それでは、2階に上がってねぶたミュージアムへ!!", "end_time": 64.0}, {"start_time": 64.0, "title": "入り口までは、小さなねぶたが飾ってありました!", "end_time": 130.0}, {"start_time": 130.0, "title": "おおっ! 威勢のいい掛け声が響き渡ります!", "end_time": 153.0}, {"start_time": 153.0, "title": "少し進むとマイねぶたを作れるコーナーが!", "end_time": 186.0}, {"start_time": 186.0, "title": "胸が高まります!これからが楽しみ!!", "end_time": 232.0}, {"start_time": 232.0, "title": "かなり近くに来ました!すごい迫力!!", "end_time": 236.0}, {"start_time": 236.0, "title": "本番の青森ねぶた祭は、凄い熱気なんだろうな", "end_time": 379.0}, {"start_time": 379.0, "title": "その他、ねぶたの構造を見たり、手で触れたり", "end_time": 383.0}, {"start_time": 383.0, "title": "歴史を学んだりと見所満載でした", "end_time": 390.0}, {"start_time": 390.0, "title": "本番以外でも、ねぶたが見られるのはいいですね", "end_time": 415.0}, {"start_time": 415.0, "title": "それでは、お土産屋さんを通って外へ!", "end_time": 423.0}, {"start_time": 423.0, "title": "今回の旅は、特にアスパム展望台からの眺めと", "end_time": 428.0}, {"start_time": 428.0, "title": "ねぶたミュージアムでの迫力あるねぶたが良かったです", "end_time": 433.0}, {"start_time": 433.0, "title": "青森駅から新青森駅へ!", "end_time": 456}], "like_count": 20, "channel": "ハッピー体験TV", "channel_follower_count": 8620, "uploader": "ハッピー体験TV", "uploader_id": "@TV-me2dt", "uploader_url": "https://www.youtube.com/@TV-me2dt", "upload_date": "20170618", "timestamp": 1497784026, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "display_id": "DxO_gE7tFZI", "full